  <library_images>
    <image id="img_textures_hw_white_dds" name="img_textures_hw_white_dds">
      <init_from>textures/hw_white.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_pillar">
      <profile_COMMON>
        <newparam sid="surf_pillar">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_pillar">
          <sampler2D>
            <source>surf_pillar</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.58 0.55 0.52 1</color></ambient>
            <diffuse><texture texture="samp_pillar" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_pillar" name="pillar">
      <instance_effect url="#Effect_pillar"/>
    </material>
  </library_materials>
