  <asset>
    <created>2026-01-01</created>
    <modified>2026-01-01</modified>
    <unit name="centimeter" meter="0.01"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_images>
    <image id="img_textures_hw_white_dds" name="img_textures_hw_white_dds">
      <init_from>textures/hw_white.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_trunk">
      <profile_COMMON>
        <newparam sid="surf_trunk">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_trunk">
          <sampler2D>
            <source>surf_trunk</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.35 0.22 0.08 1</color></ambient>
            <diffuse><texture texture="samp_trunk" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_canopy">
      <profile_COMMON>
        <newparam sid="surf_canopy">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_canopy">
          <sampler2D>
            <source>surf_canopy</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.1 0.42 0.08 1</color></ambient>
            <diffuse><texture texture="samp_canopy" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_trunk" name="trunk">
      <instance_effect url="#Effect_trunk"/>
    </material>
    <material id="Mat_canopy" name="canopy">
      <instance_effect url="#Effect_canopy"/>
    </material>
  </library_materials>
