<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <created>2026-01-01</created>
    <modified>2026-01-01</modified>
    <unit name="centimeter" meter="0.01"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_images>
    <image id="img_textures_hw_white_dds" name="img_textures_hw_white_dds">
      <init_from>textures/hw_white.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_base">
      <profile_COMMON>
        <newparam sid="surf_base">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_base">
          <sampler2D>
            <source>surf_base</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.08 0.08 0.1 1</color></ambient>
            <diffuse><texture texture="samp_base" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_neck">
      <profile_COMMON>
        <newparam sid="surf_neck">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_neck">
          <sampler2D>
            <source>surf_neck</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.08 0.08 0.1 1</color></ambient>
            <diffuse><texture texture="samp_neck" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_horn">
      <profile_COMMON>
        <newparam sid="surf_horn">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_horn">
          <sampler2D>
            <source>surf_horn</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.08 0.08 0.1 1</color></ambient>
            <diffuse><texture texture="samp_horn" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_base" name="base">
      <instance_effect url="#Effect_base"/>
    </material>
    <material id="Mat_neck" name="neck">
      <instance_effect url="#Effect_neck"/>
    </material>
    <material id="Mat_horn" name="horn">
      <instance_effect url="#Effect_horn"/>
    </material>
  </library_materials>
