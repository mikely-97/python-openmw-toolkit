  <library_effects>
    <effect id="Effect_bowl">
      <profile_COMMON>
        <newparam sid="surf_bowl">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_bowl">
          <sampler2D>
            <source>surf_bowl</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.55 0.5 0.45 1</color></ambient>
            <diffuse><texture texture="samp_bowl" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_pestle">
      <profile_COMMON>
        <newparam sid="surf_pestle">
