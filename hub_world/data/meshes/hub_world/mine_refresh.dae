          <input semantic="NORMAL"   source="#Geom_sign-normals"   offset="1"/>
          <input semantic="TEXCOORD" source="#Geom_sign-texcoords" offset="2" set="0"/>
          <p>0 0 0 1 0 0 2 0 0 3 1 0 4 1 0 5 1 0 6 2 0 7 2 0 8 2 0 9 3 0 10 3 0 11 3 0 12 4 0 13 4 0 14 4 0 15 5 0 16 5 0 17 5 0 18 6 0 19 6 0 20 6 0 21 7 0 22 7 0 23 7 0 24 8 0 25 8 0 26 8 0 27 9 0 28 9 0 29 9 0 30 10 0 31 10 0 32 10 0 33 11 0 34 11 0 35 11 0</p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="Node_board" name="board" type="NODE">
        <instance_geometry url="#Geom_board">
          <bind_material>
            <technique_common>
              <instance_material symbol="board" target="#Mat_board">
                <bind_vertex_input semantic="CHANNEL1" input_semantic="TEXCOORD" input_set="0"/>
              </instance_material>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
      <node id="Node_sign" name="sign" type="NODE">
        <instance_geometry url="#Geom_sign">
          <bind_material>
            <technique_common>
              <instance_material symbol="sign" target="#Mat_sign">
                <bind_vertex_input semantic="CHANNEL1" input_semantic="TEXCOORD" input_set="0"/>
              </instance_material>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
