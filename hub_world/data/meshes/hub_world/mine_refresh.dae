        </source>
        <source id="Geom_board-texcoords">
          <float_array id="Geom_board-texcoords-array" count="2">0 0</float_array>
          <technique_common>
            <accessor source="#Geom_board-texcoords-array" count="1" stride="2">
              <param name="S" type="float"/>
              <param name="T" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="Geom_board-vertices">
          <input semantic="POSITION" source="#Geom_board-positions"/>
        </vertices>
        <triangles count="12" material="board">
          <input semantic="VERTEX"   source="#Geom_board-vertices"  offset="0"/>
          <input semantic="NORMAL"   source="#Geom_board-normals"   offset="1"/>
          <input semantic="TEXCOORD" source="#Geom_board-texcoords" offset="2" set="0"/>
