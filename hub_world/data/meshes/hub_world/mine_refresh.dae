<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <created>2026-01-01</created>
    <modified>2026-01-01</modified>
    <unit name="centimeter" meter="0.01"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_images>
    <image id="img_textures_hw_white_dds" name="img_textures_hw_white_dds">
      <init_from>textures/hw_white.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_board">
      <profile_COMMON>
        <newparam sid="surf_board">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_board">
          <sampler2D>
            <source>surf_board</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.45 0.35 0.2 1</color></ambient>
            <diffuse><texture texture="samp_board" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_sign">
      <profile_COMMON>
        <newparam sid="surf_sign">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_sign">
          <sampler2D>
            <source>surf_sign</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.55 0.45 0.25 1</color></ambient>
            <diffuse><texture texture="samp_sign" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_board" name="board">
      <instance_effect url="#Effect_board"/>
    </material>
    <material id="Mat_sign" name="sign">
      <instance_effect url="#Effect_sign"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="Geom_board" name="board">
      <mesh>
        <source id="Geom_board-positions">
          <float_array id="Geom_board-positions-array" count="108">-30 2.5 0 30 2.5 0 30 -2.5 0 -30 2.5 0 30 -2.5 0 -30 -2.5 0 -30 -2.5 80 30 -2.5 80 30 2.5 80 -30 -2.5 80 30 2.5 80 -30 2.5 80 -30 -2.5 0 30 -2.5 0 30 -2.5 80 -30 -2.5 0 30 -2.5 80 -30 -2.5 80 30 2.5 0 -30 2.5 0 -30 2.5 80 30 2.5 0 -30 2.5 80 30 2.5 80 -30 -2.5 0 -30 -2.5 80 -30 2.5 80 -30 -2.5 0 -30 2.5 80 -30 2.5 0 30 2.5 0 30 2.5 80 30 -2.5 80 30 2.5 0 30 -2.5 80 30 -2.5 0</float_array>
          <technique_common>
            <accessor source="#Geom_board-positions-array" count="36" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
