  <asset>
    <created>2026-01-01</created>
    <modified>2026-01-01</modified>
    <unit name="centimeter" meter="0.01"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_images>
    <image id="img_textures_hw_white_dds" name="img_textures_hw_white_dds">
      <init_from>textures/hw_white.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_body">
      <profile_COMMON>
        <newparam sid="surf_body">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_body">
          <sampler2D>
            <source>surf_body</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.55 0.4 0.2 1</color></ambient>
            <diffuse><texture texture="samp_body" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
    <effect id="Effect_neck">
      <profile_COMMON>
        <newparam sid="surf_neck">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_neck">
          <sampler2D>
            <source>surf_neck</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.5 0.35 0.15 1</color></ambient>
            <diffuse><texture texture="samp_neck" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_body" name="body">
      <instance_effect url="#Effect_body"/>
    </material>
    <material id="Mat_neck" name="neck">
      <instance_effect url="#Effect_neck"/>
    </material>
  </library_materials>
