  <library_effects>
    <effect id="Effect_frame_green">
      <profile_COMMON>
        <newparam sid="surf_frame_green">
          <surface type="2D">
            <init_from>img_textures_hw_white_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_frame_green">
          <sampler2D>
            <source>surf_frame_green</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.12 0.72 0.12 1</color></ambient>
            <diffuse><texture texture="samp_frame_green" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
