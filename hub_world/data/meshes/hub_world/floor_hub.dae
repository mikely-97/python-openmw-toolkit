<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <created>2026-01-01</created>
    <modified>2026-01-01</modified>
    <unit name="centimeter" meter="0.01"/>
    <up_axis>Z_UP</up_axis>
  </asset>
  <library_images>
    <image id="img_textures_hw_brick_dds" name="img_textures_hw_brick_dds">
      <init_from>textures/hw_brick.dds</init_from>
    </image>
  </library_images>
  <library_effects>
    <effect id="Effect_floor_hub">
      <profile_COMMON>
        <newparam sid="surf_floor_hub">
          <surface type="2D">
            <init_from>img_textures_hw_brick_dds</init_from>
          </surface>
        </newparam>
        <newparam sid="samp_floor_hub">
          <sampler2D>
            <source>surf_floor_hub</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <blinn>
            <emission><color sid="emission">0 0 0 1</color></emission>
            <ambient><color sid="ambient">0.45 0.45 0.45 1</color></ambient>
            <diffuse><texture texture="samp_floor_hub" texcoord="CHANNEL1"/></diffuse>
            <specular><color sid="specular">0.1 0.1 0.1 1</color></specular>
            <shininess><float sid="shininess">20</float></shininess>
          </blinn>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_materials>
    <material id="Mat_floor_hub" name="floor_hub">
      <instance_effect url="#Effect_floor_hub"/>
    </material>
  </library_materials>
  <library_geometries>
    <geometry id="Geom_floor_hub" name="floor_hub">
      <mesh>
        <source id="Geom_floor_hub-positions">
